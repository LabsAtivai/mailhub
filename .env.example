# Copie este arquivo para .env e preencha os valores de produção

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://mailhub:<POSTGRES_PASSWORD>@mailhub-postgres:5432/mailhub

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:<REDIS_PASSWORD>@mailhub-redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Criptografia IMAP (MESMO valor no backend e no worker) ────────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://seu-dominio.com
VITE_API_URL=/

# ── Envio de e-mail (opcional) ────────────────────────────────────────────────
SENDGRID_API_KEY=
